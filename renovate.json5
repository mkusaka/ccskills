{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices", "group:definitelyTyped"],
  packageRules: [
    {
      description: "Group minor, patch, and pin updates for npm dependencies",
      groupName: "npm dependencies (non-major)",
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
      matchManagers: ["npm"],
      matchDepTypes: ["dependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
    },
    {
      description: "Group minor, patch, and pin updates for npm devDependencies",
      groupName: "npm devDependencies (non-major)",
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch", "pin"],
    },
    {
      description: "Group minor, patch, digest, and pinDigest updates for GitHub Actions",
      groupName: "github-actions (non-major)",
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch", "digest", "pinDigest"],
    },
  ],
}
